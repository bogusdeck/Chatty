NODE_ENV=development
PORT=3443
JWT_SECRET=replace-this-with-a-long-random-secret
TRUST_PROXY=false

# Demo users — Format: username:password,username2:password2
AUTH_USERS=alice:password123,bob:password123

# ── Production / Render ────────────────────────────────
# When deploying on Render (or any reverse-proxy host):
#   NODE_ENV=production
#   TRUST_PROXY=true        <-- run HTTP internally; Render handles TLS
#   PORT=10000              <-- Render default
#   JWT_SECRET=<auto-generated by Render or set manually>
#   AUTH_USERS=<your:password,pairs>
# TLS_KEY_PATH and TLS_CERT_PATH are NOT needed on Render.

# ── HTTPS (standalone, no proxy) ──────────────────────
TLS_KEY_PATH=
TLS_CERT_PATH=

# ── Optional TURN server ───────────────────────────────
# Needed for peers behind strict NAT/firewalls.
TURN_URL=
TURN_USERNAME=
TURN_PASSWORD=
